<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".PasswordActivity">


    <TextView
        android:id="@+id/PasswordWelcomeTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="70dp"
        android:text="Welcome back,please sign in to continue"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <EditText
        android:id="@+id/PasswordEditText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="28dp"
        android:hint="Enter your password"
        android:inputType="textPassword"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/PasswordWelcomeTextView" />

    <Button
        android:id="@+id/PasswordNextButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginBottom="30dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:text="@string/next"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/PasswordSignInErrorTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:text="I can't sign in"
        app:layout_constraintBottom_toTopOf="@+id/PasswordNextButton"
        app:layout_constraintStart_toStartOf="@+id/PasswordNextButton" />

    <TextView
        android:id="@+id/PasswordNoAccountTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:text="I don't have an account"
        app:layout_constraintBottom_toTopOf="@+id/PasswordSignInErrorTextView"
        app:layout_constraintStart_toStartOf="@+id/PasswordSignInErrorTextView" />

    <TextView
        android:id="@+id/PasswordForgotTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="I forgot my password"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toTopOf="@+id/PasswordNoAccountTextView"
        app:layout_constraintStart_toStartOf="@+id/PasswordNoAccountTextView" />

</androidx.constraintlayout.widget.ConstraintLayout>